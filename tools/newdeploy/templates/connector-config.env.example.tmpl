# =====================================================================
#  retail-ops-mcp-kit — connector config for deployment: {{CUSTOMER}} ({{SLUG}})
#  Stamped by {{GENERATOR}}. Copy to  .local/connector-config.env  and fill.
#
#  Source kit (referenced BY NAME, not vendored into this deployment):
#    frameworks/agents/retail-ops-mcp-kit   (src package: retail_ops_mcp)
#  Four small MCP servers, one per enterprise-system class the agent
#  integrates (ERP / supplier network / email / spreadsheet). Each server
#  models a real named SaaS on the wire, selected by the env var below;
#  active_system() on each server confirms the wired dialect without
#  leaking any credential.
# =====================================================================

# --- Which named SaaS each server models on the wire -----------------
# retail-erp-mcp        allowed: sap_s4hana | netsuite | dynamics365
RETAIL_ERP_SYSTEM={{ERP_SYSTEM}}
# retail-supplier-mcp   allowed: sps_commerce | coupa | ariba
RETAIL_SUPPLIER_SYSTEM={{SUPPLIER_SYSTEM}}
# retail-email-mcp      allowed: msgraph | gmail
RETAIL_EMAIL_SYSTEM={{EMAIL_SYSTEM}}
# retail-sheets-mcp     allowed: google_sheets | msgraph_excel
RETAIL_SHEETS_SYSTEM={{SHEETS_SYSTEM}}

# --- Human proof-of-presence approval token (IDENTICAL on all four) --
# {{APPROVAL_TOKEN_VAR}} is the human token for approve(approval_id, token),
# compared with hmac.compare_digest. The agent structurally CANNOT read it:
# it is never a tool return, never in the corpus, never a default. Absent /
# unset => every approval FAILS CLOSED (refused).
#
# Inject this at run time from the operator/host env or a secrets manager.
# NEVER commit a real value. NEVER expose it to the agent. Keep it in
# .local/-class storage, not VCS.
{{APPROVAL_TOKEN_VAR}}=<operator-injected; NOT known to the agent>
